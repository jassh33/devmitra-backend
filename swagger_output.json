          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "firstName",
                  "lastName",
                  "phone"
                ],
                "properties": {
                  "firstName": {
                    "type": "string",
                    "example": "Ramesh"
                  },
                  "lastName": {
                    "type": "string",
                    "example": "Sharma"
                  },
                  "phone": {
                    "type": "string",
                    "example": "919876543210"
                  },
                  "city": {
                    "type": "string",
                    "example": "Hyderabad"
                  },
                  "poojariCategory": {
                    "type": "string",
                    "example": "Vedic Pandit"
                  },
                  "languages": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "example": [
                      "Telugu",
                      "Hindi"
                    ]
                  },
                  "studyPlace": {
                    "type": "string",
                    "example": "Tirupati"
                  },
                  "experience": {
                    "type": "number",
                    "example": 10
                  },
                  "profileImage": {
                    "type": "string",
                    "example": "/public/profiles/12345.jpg"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Customer created successfully"
          },
          "500": {
            "description": "Error creating customer"
          }
        }
      },
      "get": {
        "summary": "Get all customers",
        "tags": [
          "Customers"
        ],
        "responses": {
          "200": {
            "description": "List of customers"
          },
          "500": {
            "description": "Error fetching customers"
          }
        }
      }
